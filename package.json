{
  "name": "@jettaz/nuxt-maintenance-mode",
  "version": "1.1.12",
  "author": {
    "name": "jettaz",
    "url": "https://jettaz.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/jettaz/nuxt-maintenance-mode#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jettaz/nuxt-maintenance-mode.git"
  },
  "bugs": {
    "url": "https://github.com/jettaz/nuxt-maintenance-mode/issues"
  },
  "description": "Nuxt module for maintenance mode with PIN verification",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "nuxt4",
    "maintenance",
    "maintenance-mode",
    "pin",
    "bypass"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "types": "./dist/module.d.mts",
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "maintenance-setup": "bin/setup.js"
  },
  "scripts": {
    "postinstall": "node bin/setup.js --postinstall",
    "build": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "test": "vitest run",
    "prepare": "npm run build",
    "release": "npm run build && npm publish --access public"
  },
  "dependencies": {
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/module-builder": "^1.0.0",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^3.15.4",
    "nuxt": "^4.4.2",
    "vitest": "^3.2.0",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "nuxt": ">=4.0.0"
  }
}
